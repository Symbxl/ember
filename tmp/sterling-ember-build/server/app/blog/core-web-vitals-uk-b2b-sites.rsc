1f:T5f7,{"@context":"https://schema.org","@type":"BlogPosting","headline":"Core Web Vitals: Why UK B2B Sites Score Worse Than US Equivalents","alternativeHeadline":"We pulled CrUX data on 200 .co.uk B2B sites against 200 US peers. The UK cohort underperforms on every CWV metric. Five causes account for 80% of the gap.","description":"British marketing sites consistently fail Core Web Vitals at higher rates than US peers. We dug into 200 .co.uk sites and identified the five recurring causes — and how to fix them.","image":["https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=1800&q=80","https://sterlingember.com/blog/og/core-web-vitals-uk-b2b-sites"],"datePublished":"2026-03-30","dateModified":"2026-05-04","inLanguage":"en-GB","author":{"@type":"Person","@id":"https://sterlingember.com/blog/author/theo-ember","name":"Theo Ember","jobTitle":"Engineering Lead","url":"https://sterlingember.com/blog/author/theo-ember","image":"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=400&q=80"},"publisher":{"@type":"Organization","name":"Ember Sterling","url":"https://sterlingember.com","logo":{"@type":"ImageObject","url":"https://sterlingember.com/logo1.webp"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://sterlingember.com/blog/core-web-vitals-uk-b2b-sites"},"keywords":"Core Web Vitals UK, LCP, INP, Next.js performance, UK B2B websites, site speed UK","articleSection":"Web Development","wordCount":589,"timeRequired":"PT9M","isAccessibleForFree":true}20:T448,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What's a good Core Web Vitals score in 2026?","acceptedAnswer":{"@type":"Answer","text":"Google's 'Good' thresholds are: LCP under 2.5s, INP under 200ms, CLS under 0.1, measured at the 75th percentile of real-user data in CrUX. Hitting all three thresholds on at least 75% of pageviews qualifies a URL as 'passing'."}},{"@type":"Question","name":"Does Core Web Vitals affect SEO rankings?","acceptedAnswer":{"@type":"Answer","text":"Yes, but as a tiebreaker rather than a primary signal. CWV is part of Google's Page Experience signal. In competitive UK niches we see clear ranking lift when sites move from 'Needs Improvement' to 'Good', particularly on mobile."}},{"@type":"Question","name":"How do I measure INP accurately?","acceptedAnswer":{"@type":"Answer","text":"INP requires real-user monitoring — lab tools like Lighthouse can only estimate it. Use the web-vitals JavaScript library to report INP to your analytics, or pull from the Chrome User Experience Report (CrUX) BigQuery export."}}]}14:[["$","$L1e",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1f"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://sterlingember.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://sterlingember.com/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Web Development\",\"item\":\"https://sterlingember.com/blog/category/web-development\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Core Web Vitals: Why UK B2B Sites Score Worse Than US Equivalents\",\"item\":\"https://sterlingember.com/blog/core-web-vitals-uk-b2b-sites\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$20"}}],"$L21","$L22","$L23","$L24","$L25"]
