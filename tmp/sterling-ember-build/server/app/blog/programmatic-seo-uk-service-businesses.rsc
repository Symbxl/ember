31:["$","h2","17",{"id":"what-not-to-do","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":["$","a",null,{"href":"#what-not-to-do","className":"no-underline","children":[["$","span",null,{"children":"What not to do"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]}]
32:["$","p","18",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"Don't programmatically generate pages from GPT alone. Don't deploy 2,000 pages in one go. Don't skip the data-asset step. Don't use canonical URLs to point all the programmatic pages at one master page — Google sees through it, and you wasted the crawl budget. Do build the system on top of data your business already collects, and you'll have something Google can't easily replicate."}]
