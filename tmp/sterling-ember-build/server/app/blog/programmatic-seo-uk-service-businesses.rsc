26:["$","a",null,{"href":"#what-made-it-not-spam","className":"no-underline","children":[["$","span",null,{"children":"What kept it on the right side of useful"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]
27:["$","p","7",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"Every page had at least three sources of genuinely unique content per location: anonymised summaries of recent jobs done in that postcode, a real photo from a real job there, and pricing context based on the average ticket from the last 90 days of work in that area. That data already existed in the client's job-management system. We just had to plumb it (no pun intended) into the page generation pipeline."}]
28:["$","aside","8",{"className":"mt-8 glass-strong p-6 border-l-4 border-l-ember-500","children":[["$","div",null,{"className":"text-xs font-bold uppercase tracking-[0.18em] text-ember-600","children":"The principle"}],["$","p",null,{"className":"mt-2 text-ink-100","children":"Programmatic SEO works when you have a real data asset the user wants to see. It fails when you're just templating a city name into a wall of generic copy. If you can't point to three things on each page that change based on the location and would be useful to the reader, kill the project."}]]}]
