21:["$","div",null,{"className":"mt-6 max-w-3xl animate-fade-up","children":[["$","$L6",null,{"href":"/blog/category/seo","className":"eyebrow hover:text-ember-600 transition-colors","children":[["$","span",null,{"className":"h-px w-6 bg-ember-500"}],"SEO"]}],["$","h1",null,{"className":"mt-3 font-display font-semibold text-4xl md:text-6xl tracking-tight text-ink-50","children":"Programmatic SEO for UK Service Businesses: A Case-Study Breakdown"}],["$","p",null,{"className":"mt-5 text-lg text-ink-300","children":"We grew a UK plumbing franchise from 4,200 to 38,000 monthly organic sessions in nine months using programmatic SEO. Here's the architecture and what made it work."}],["$","div",null,{"className":"mt-7 flex items-center gap-3","children":["$","$L6",null,{"href":"/blog/author/marco-vela","className":"flex items-center gap-3 group","aria-label":"More posts by Marco Vela","children":[["$","$L7",null,{"src":"https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?auto=format&fit=crop&w=400&q=80","alt":"","width":44,"height":44,"className":"rounded-full border border-ink-700"}],["$","div",null,{"className":"text-sm","children":[["$","div",null,{"className":"font-semibold text-ink-50 group-hover:text-ember-600 transition-colors","children":"Marco Vela"}],["$","div",null,{"className":"text-ink-400","children":[["$","time",null,{"dateTime":"2025-12-12","children":"11 December 2025"}],["$","span",null,{"aria-hidden":true,"children":" · "}],["$","span",null,{"children":[12," min read"]}],[" · Updated ",["$","time",null,{"dateTime":"2026-03-08","children":"7 March 2026"}]]]}]]}]]}]}]]}]
22:["$","section",null,{"className":"bg-white","children":["$","div",null,{"className":"container-x","children":["$","div",null,{"className":"relative aspect-[16/8] overflow-hidden rounded-3xl border border-ink-700 shadow-lift","children":["$","$L7",null,{"src":"https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1800&q=80","alt":"Whiteboard covered in keyword maps and architecture diagrams","fill":true,"priority":true,"sizes":"(min-width: 1024px) 80vw, 100vw","className":"object-cover"}]}]}]}]
23:["$","section",null,{"className":"bg-white pt-16 pb-24","children":["$","div",null,{"className":"container-x grid gap-12 lg:grid-cols-[1fr_260px]","children":[["$","article",null,{"data-progress-target":true,"className":"max-w-3xl prose-base","children":[[["$","p","0",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"Programmatic SEO is the practice of generating large numbers of pages from a structured dataset — service × location, integration × tool, problem × industry. Google's quality team has been very clear: programmatic SEO is fine if the resulting pages are useful, terrible if they're not. The line is whether each page would justify its own existence to a human. This is a breakdown of a UK plumbing franchise case study where we crossed that line carefully."}],["$","h2","1",{"id":"the-setup","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":["$","a",null,{"href":"#the-setup","className":"no-underline","children":[["$","span",null,{"children":"The starting position"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]}],["$","p","2",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"Client was a 42-branch UK plumbing and heating franchise. Marketing site on WordPress. Forty-two location pages — basically templates with the city name swapped in. 4,200 organic sessions per month from a domain that should have been doing 10x. Nine months later, we'd shipped 1,840 pages and the site was at 38,000 sessions per month. No black-hat tricks. Just a careful programmatic architecture."}],["$","h2","3",{"id":"the-matrix","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":["$","a",null,{"href":"#the-matrix","className":"no-underline","children":[["$","span",null,{"children":"The service × location matrix"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]}],["$","p","4",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"Step one was mapping the matrix. 24 services (boiler repair, emergency plumbing, gas safety inspection, etc.) × 78 postcode areas covered by the franchise = 1,872 potential pages. We pruned to 1,840 by removing combinations that weren't real services in certain areas."}],["$","ul","5",{"className":"mt-6 space-y-3","children":[["$","li","0",{"className":"flex items-start gap-3 text-ink-200 text-lg leading-relaxed","children":[["$","span",null,{"aria-hidden":true,"className":"mt-2.5 inline-block h-1.5 w-1.5 rounded-full bg-ember-500 shrink-0"}],["$","span",null,{"children":"URL structure: /services/[service]/[postcode-area] — flat, predictable, and matched search intent."}]]}],["$","li","1",{"className":"flex items-start gap-3 text-ink-200 text-lg leading-relaxed","children":[["$","span",null,{"aria-hidden":true,"className":"mt-2.5 inline-block h-1.5 w-1.5 rounded-full bg-ember-500 shrink-0"}],["$","span",null,{"children":"Each page got a unique H1 templated from real local search volume data, not arbitrary city name + service."}]]}],["$","li","2",{"className":"flex items-start gap-3 text-ink-200 text-lg leading-relaxed","children":[["$","span",null,{"aria-hidden":true,"className":"mt-2.5 inline-block h-1.5 w-1.5 rounded-full bg-ember-500 shrink-0"}],["$","span",null,{"children":"Service definition (consistent), local availability info (unique per postcode area), pricing context (averaged from real jobs), engineer count (real), example past jobs (real)."}]]}]]}],["$","h2","6",{"id":"what-made-it-not-spam","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":"$L26"}],"$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32"],"$undefined","$L33","$L34","$L35"]}],"$L36"]}]}]
