22:["$","section",null,{"className":"bg-white pt-16 pb-24","children":["$","div",null,{"className":"container-x grid gap-12 lg:grid-cols-[1fr_260px]","children":[["$","article",null,{"data-progress-target":true,"className":"max-w-3xl prose-base","children":[[["$","p","0",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"The Information Commissioner's Office published updated cookie guidance on 9 January 2026, with enforcement targets named for the second half of the year. Most UK marketing sites — including a significant share of the FTSE 250 — are now technically out of compliance. This isn't a legal article (talk to a solicitor for that). It's a practical implementation checklist from the engineering side."}],["$","h2","1",{"id":"what-changed","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":["$","a",null,{"href":"#what-changed","className":"no-underline","children":[["$","span",null,{"children":"What actually changed"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]}],["$","ul","2",{"className":"mt-6 space-y-3","children":[["$","li","0",{"className":"flex items-start gap-3 text-ink-200 text-lg leading-relaxed","children":[["$","span",null,{"aria-hidden":true,"className":"mt-2.5 inline-block h-1.5 w-1.5 rounded-full bg-ember-500 shrink-0"}],["$","span",null,{"children":"'Reject All' must be on the first layer of the banner, presented with equal prominence to 'Accept All'."}]]}],["$","li","1",{"className":"flex items-start gap-3 text-ink-200 text-lg leading-relaxed","children":[["$","span",null,{"aria-hidden":true,"className":"mt-2.5 inline-block h-1.5 w-1.5 rounded-full bg-ember-500 shrink-0"}],["$","span",null,{"children":"Implied consent (continuing to use the site = accept) is now explicitly non-compliant for non-essential cookies."}]]}],["$","li","2",{"className":"flex items-start gap-3 text-ink-200 text-lg leading-relaxed","children":[["$","span",null,{"aria-hidden":true,"className":"mt-2.5 inline-block h-1.5 w-1.5 rounded-full bg-ember-500 shrink-0"}],["$","span",null,{"children":"Cookie walls — where access to content is conditioned on accepting cookies — are non-compliant unless paid alternatives exist."}]]}],["$","li","3",{"className":"flex items-start gap-3 text-ink-200 text-lg leading-relaxed","children":[["$","span",null,{"aria-hidden":true,"className":"mt-2.5 inline-block h-1.5 w-1.5 rounded-full bg-ember-500 shrink-0"}],["$","span",null,{"children":"The ICO can now issue fines based on global turnover, aligned with EU GDPR maximums."}]]}]]}],["$","h2","3",{"id":"consent-mode","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":["$","a",null,{"href":"#consent-mode","className":"no-underline","children":[["$","span",null,{"children":"Google Consent Mode v2 is now load-bearing"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]}],["$","p","4",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"If you run Google Ads or GA4 and you want to keep modelled conversions when users decline, you need Consent Mode v2 properly implemented. The default in most CMPs ships it half-configured. Specifically: 'ad_user_data' and 'ad_personalization' default to 'denied' in v2, but the default 'analytics_storage' setting must also be 'denied' until consent is given — and a lot of implementations get this wrong."}],["$","aside","5",{"className":"mt-8 glass-strong p-6 border-l-4 border-l-ember-500","children":[["$","div",null,{"className":"text-xs font-bold uppercase tracking-[0.18em] text-ember-600","children":"What 'wrong' looks like"}],"$L25"]}],"$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c"],"$L2d","$L2e","$L2f","$L30"]}],"$L31"]}]}]
