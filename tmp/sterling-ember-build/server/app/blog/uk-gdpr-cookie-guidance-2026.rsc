"className":"flex items-start gap-3 text-ink-200 text-lg leading-relaxed","children":[["$","span",null,{"aria-hidden":true,"className":"mt-1 grid h-6 w-6 place-items-center rounded-full bg-ember-500/15 text-ember-600 text-xs font-bold shrink-0","children":6}],["$","span",null,{"children":"Cookie list kept in sync with what's actually firing — run a Tarte audit quarterly."}]]}],["$","li","6",{"className":"flex items-start gap-3 text-ink-200 text-lg leading-relaxed","children":[["$","span",null,{"aria-hidden":true,"className":"mt-1 grid h-6 w-6 place-items-center rounded-full bg-ember-500/15 text-ember-600 text-xs font-bold shrink-0","children":7}],["$","span",null,{"children":"Consent Mode v2 verified in production using the Tag Assistant debugger."}]]}]]}]
