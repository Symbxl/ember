26:["$","aside","6",{"className":"mt-8 glass-strong p-6 border-l-4 border-l-ember-500","children":[["$","div",null,{"className":"text-xs font-bold uppercase tracking-[0.18em] text-ember-600","children":"Quick win"}],["$","p",null,{"className":"mt-2 text-ink-100","children":"Audit your GBP description for the five UK-specific signals: a named neighbourhood, the borough or council, two service modifiers, hours expressed in the 24-hour clock, and at least one named team member. We see a 12–18% lift in profile views within four weeks of tightening this."}]]}]
27:["$","h2","7",{"id":"location-pages","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":["$","a",null,{"href":"#location-pages","className":"no-underline","children":[["$","span",null,{"children":"Location pages that don't read like templates"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]}]
28:["$","p","8",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"Templated location pages — the kind where only the city name and postcode change — are the single most common reason UK multi-location brands stall in local rank. Google's site quality classifier now models page-to-page similarity across a domain. If your Birmingham page is 92% similar to your Bristol page, both get downweighted."}]
29:["$","p","9",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"The fix is dull and expensive: every location page needs at least 250 words of unique, on-the-ground content. Named team members. Local photos (not stock). One paragraph about the surrounding area written by someone who has been there. Two embedded reviews from customers in that catchment. Service hours expressed in local context (e.g. 'open before the school run')."}]
