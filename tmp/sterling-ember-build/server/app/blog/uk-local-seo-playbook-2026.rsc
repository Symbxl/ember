2b:["$","h2","11",{"id":"schema","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":["$","a",null,{"href":"#schema","className":"no-underline","children":[["$","span",null,{"children":"Schema that the SERP can use"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]}]
2c:["$","p","12",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"On each location page, ship LocalBusiness with the exact UK postcode, openingHoursSpecification using 24-hour format, areaServed using GeoCircle, and sameAs linking to the matching Google Business Profile, Bing Places, Yell, and Companies House listings. The Companies House link is underrated — it gives Google an external trust signal that's hard to fake."}]
2d:["$","p","13",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"We also ship Service schema for each named service offered at that location, with a serviceArea matching the catchment. This is what feeds the AI Overview when a user searches '[service] near me' from a UK IP."}]
2e:["$","h2","14",{"id":"citations","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":["$","a",null,{"href":"#citations","className":"no-underline","children":[["$","span",null,{"children":"Citations: cleanup matters more than volume"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]}]
2f:["$","p","15",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"Most UK brands have 60+ citations and don't know it. The job isn't building more — it's resolving the contradictions. Run a NAP audit across Yell, Thomson Local, FreeIndex, Scoot, Yelp UK, Bing Places, Apple Business Connect, and Companies House. Standardise the phone format ('+44 20 7946 0958', not '0207 946 0958' or '020 7946 0958'). Fix the address line order — UK formatting differs from US."}]
30:["$","aside","16",{"className":"mt-8 glass-strong p-6 border-l-4 border-l-ember-500","children":[["$","div",null,{"className":"text-xs font-bold uppercase tracking-[0.18em] text-ember-600","children":"The 90-day target"}],["$","p",null,{"className":"mt-2 text-ink-100","children":"Three months in, you should see: (1) GBP profile views up 25%+, (2) at least one location ranking in the local 3-pack for a primary service term, (3) AI Overview citations on two non-brand queries, (4) zero NAP discrepancies in a Whitespark scan."}]]}]
31:["$","h2","17",{"id":"measurement","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 mt-14 scroll-mt-24 group","children":["$","a",null,{"href":"#measurement","className":"no-underline","children":[["$","span",null,{"children":"How to measure it without lying to yourself"}],["$","span",null,{"aria-hidden":true,"className":"ml-2 text-ember-500/0 group-hover:text-ember-500/80 transition-colors text-base","children":"#"}]]}]}]
32:["$","p","18",{"className":"text-ink-200 text-lg leading-relaxed mt-6","children":"Most local SEO dashboards report rank tracking by city — useless if your business operates at the suburb level. We track per-location GBP impressions, direction requests, and calls in GA4 with a custom dimension for the location ID. Every conversion gets attributed to the location that drove it. Aggregate views hide the locations that are actually working — and the ones quietly bleeding budget."}]
33:["$","div",null,{"className":"mt-16","children":[["$","h2",null,{"id":"faq","className":"font-display font-semibold text-2xl md:text-3xl text-ink-50 scroll-mt-24","children":"Frequently asked questions"}],["$","div",null,{"className":"mt-6 divide-y divide-ink-700 border-y border-ink-700","children":[["$","details","0",{"className":"group py-5","children":[["$","summary",null,{"className":"flex cursor-pointer items-center justify-between gap-4 list-none","children":[["$","span",null,{"className":"font-semibold text-ink-50","children":"How long does UK local SEO take to show results?"}],["$","span",null,{"aria-hidden":true,"className":"grid h-7 w-7 shrink-0 place-items-center rounded-full border border-ink-700 text-ink-300 transition-transform group-open:rotate-45","children":["$","svg",null,{"width":"12","height":"12","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2.5","strokeLinecap":"round","children":[["$","path",null,{"d":"M12 5v14"}],["$","path",null,{"d":"M5 12h14"}]]}]}]]}],["$","p",null,{"className":"mt-3 text-ink-300 leading-relaxed","children":"For a multi-location brand starting from a baseline of thin location pages, expect 8–12 weeks for Google Business Profile lift and 3–6 months for organic 3-pack rankings on competitive service terms. Citations cleanup compounds over time and rarely shows linear movement."}]]}],["$","details","1",{"className":"group py-5","children":[["$","summary",null,{"className":"flex cursor-pointer items-center justify-between gap-4 list-none","children":[["$","span",null,{"className":"font-semibold text-ink-50","children":"Do I need a separate Google Business Profile for every location?"}],["$","span",null,{"aria-hidden":true,"className":"grid h-7 w-7 shrink-0 place-items-center rounded-full border border-ink-700 text-ink-300 transition-transform group-open:rotate-45","children":["$","svg",null,{"width":"12","height":"12","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2.